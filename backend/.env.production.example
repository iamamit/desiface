# Copy to .env.production and fill in real values

# Database — use a strong password, not the dev default
DATABASE_URL=postgresql://desiface:STRONG_PASSWORD@db:5432/desiface

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

# Token expiry (7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — set to your actual domain(s)
CORS_ORIGINS=["https://yourdomain.com"]

# Email (Resend, SendGrid, or any SMTP provider)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=YOUR_RESEND_API_KEY
FROM_EMAIL=noreply@yourdomain.com

# Frontend URL for email links
FRONTEND_URL=https://yourdomain.com

# MUST be False in production
DEV_MODE=False
