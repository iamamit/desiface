# Copy to .env.production and fill in real values.
# This file is used by docker-compose.prod.yml

# Your domain (Caddy uses this for automatic HTTPS)
DOMAIN=yourdomain.com

# PostgreSQL password (must match backend/.env.production DATABASE_URL)
POSTGRES_USER=desiface
POSTGRES_PASSWORD=STRONG_PASSWORD
POSTGRES_DB=desiface

# Public URL for the frontend Next.js build (baked at build time)
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_WS_URL=wss://yourdomain.com
